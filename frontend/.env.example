# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# API base URL (no trailing slash)
VITE_API_URL=http://localhost:5000

# Google Maps embed API key (for contact page map)
VITE_GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Hospital info (used across pages)
VITE_HOSPITAL_NAME=Meru Doctors' Plaza Hospital
VITE_HOSPITAL_PHONE=+254700000100
VITE_HOSPITAL_EMERGENCY=+254700000911
VITE_HOSPITAL_EMAIL=info@merudoctorsplaza.co.ke
