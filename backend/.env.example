# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (PostgreSQL) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=meru_doctors_plaza
DB_USER=mdp_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT Authentication ────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── Email (SMTP) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@merudoctorsplaza.co.ke
SMTP_PASS=YOUR_APP_PASSWORD
EMAIL_FROM="Meru Doctors' Plaza <noreply@merudoctorsplaza.co.ke>"

# ── CORS ──────────────────────────────────────────────────────────
FRONTEND_URL=https://merudoctorsplaza.co.ke

# ── Rate limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
